{
  "$defs": {
    "CORSConfig": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "origins": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "CORSConfig",
      "type": "object"
    },
    "CacheConfig": {
      "additionalProperties": false,
      "properties": {
        "connection_string": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "description": "Cache provider (redis, memcached, etc.)",
          "type": "string"
        },
        "ttl_seconds": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "CacheConfig",
      "type": "object"
    },
    "EntityDefinition": {
      "additionalProperties": false,
      "properties": {
        "features": {
          "items": {
            "enum": [
              "audit",
              "audit_log",
              "soft_delete",
              "optimistic_lock"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "fields": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "indexes": {
          "items": {
            "$ref": "#/$defs/IndexDefinition"
          },
          "type": "array"
        },
        "permissions": {
          "$ref": "#/$defs/EntityPermissions"
        },
        "seed": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "fields"
      ],
      "title": "EntityDefinition",
      "type": "object"
    },
    "EntityPermissions": {
      "additionalProperties": false,
      "properties": {
        "create": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "delete": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "read": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "read_public": {
          "type": "string"
        },
        "update": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "title": "EntityPermissions",
      "type": "object"
    },
    "IndexDefinition": {
      "additionalProperties": false,
      "properties": {
        "fields": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sort": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "type": "string"
        },
        "unique": {
          "type": "boolean"
        }
      },
      "required": [
        "fields"
      ],
      "title": "IndexDefinition",
      "type": "object"
    },
    "MultiTenancy": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "MultiTenancy",
      "type": "object"
    },
    "Project": {
      "additionalProperties": false,
      "properties": {
        "cache": {
          "$ref": "#/$defs/CacheConfig"
        },
        "cors": {
          "$ref": "#/$defs/CORSConfig"
        },
        "description": {
          "type": "string"
        },
        "multi_tenancy": {
          "$ref": "#/$defs/MultiTenancy"
        },
        "name": {
          "type": "string"
        },
        "platform": {
          "description": "Target platform version (e.g. net9.0, net8.0)",
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Project",
      "type": "object"
    }
  },
  "$id": "domain.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "api_style": {
      "enum": [
        "rest",
        "graphql",
        "grpc"
      ],
      "type": "string"
    },
    "auth": {
      "type": "string"
    },
    "database": {
      "enum": [
        "postgresql",
        "mysql",
        "sqlite",
        "mssql",
        "mongodb"
      ],
      "type": "string"
    },
    "entities": {
      "additionalProperties": {
        "$ref": "#/$defs/EntityDefinition"
      },
      "type": "object"
    },
    "enums": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "type": "object"
    },
    "project": {
      "$ref": "#/$defs/Project"
    }
  },
  "required": [
    "project",
    "entities"
  ],
  "title": "DomainCraft domain.yaml schema",
  "type": "object"
}
